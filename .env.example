# Copy this file to .env and fill in the values.
# ANTHROPIC_API_KEY is consumed by LiteLLM to call api.anthropic.com.
# It is never forwarded to Claude Code clients directly.
ANTHROPIC_API_KEY=sk-ant-...

# Master key clients must present as ANTHROPIC_AUTH_TOKEN to authenticate with the proxy.
# Choose any strong random string — it never leaves your machine.
LITELLM_MASTER_KEY=sk-...
